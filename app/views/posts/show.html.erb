<p style="color: green"><%= notice %></p>

<%= render @post %>

<div class="container mx-auto px-4 py-8">
  <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4 leading-tight"><%= @post.title %></h1>
    <p class="text-gray-600 text-lg mb-6">Publicado el: <%= @post.publishd_at&.strftime("%B %d, %Y") || "Sin fecha" %></p>

    <div class="prose max-w-none text-gray-800 leading-relaxed text-lg mb-8">
      <%# Aquí puedes añadir un editor de texto enriquecido más adelante %>
      <%= simple_format(@post.content) %> <%# simple_format convierte saltos de línea en <p> y <br> %>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200 flex space-x-4">
      <%= link_to "Volver a Posts", posts_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
      <% if user_signed_in? %>
        <%= link_to "Editar este post", edit_post_path(@post), class: "text-green-600 hover:text-green-800 font-medium" %>
        <%= button_to "Eliminar este post", @post, method: :delete, data: { turbo_confirm: '¿Estás seguro de que quieres eliminar esta publicación?' }, class: "text-red-600 hover:text-red-800 font-medium" %>
      <% end %>
    </div>
  </div>
</div>
